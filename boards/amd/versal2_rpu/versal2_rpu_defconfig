# Enable UART driver
CONFIG_SERIAL=y

# Enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable serial port
CONFIG_UART_PL011=y

CONFIG_ARM_ARCH_TIMER=y

CONFIG_CACHE_MANAGEMENT=y

# Enable UFS Disk, Drivers
CONFIG_DISK_ACCESS=y
CONFIG_DISK_DRIVER_UFS=y
CONFIG_UFS_STACK=y
CONFIG_SCSI=y
CONFIG_UFSHC=y

# Heap Memory
CONFIG_HEAP_MEM_POOL_SIZE=16384
