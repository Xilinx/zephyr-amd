# Enable UART driver
CONFIG_SERIAL=y

# Enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable serial port
CONFIG_UART_PL011=y

# Enable cache and arch timer
CONFIG_CACHE_MANAGEMENT=y
CONFIG_ARM_ARCH_TIMER=y

# Heap Memory
CONFIG_HEAP_MEM_POOL_SIZE=16384

# Prevent GIC re-initialization in AMP configurations
CONFIG_GIC_SAFE_CONFIG=y
