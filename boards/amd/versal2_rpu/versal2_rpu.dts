/dts-v1/;
#include <arm/xilinx/versal2_r52.dtsi>

/ {
	chosen {
		zephyr,sram = &sram0;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,ocm = &ocm;
	};

	aliases {
		ufs0 = &ufs0;
		dma0 = &adma0;
		dma1 = &adma1;
		dma2 = &adma2;
		dma3 = &adma3;
		dma4 = &adma4;
		dma5 = &adma5;
		dma6 = &adma6;
		dma7 = &adma7;
	};

	ufs_core_clk: ufs-core-clk {
		compatible = "fixed-clock";
		clock-frequency = <300000000>;
		#clock-cells = <0>;
	};

	sdhci_ref_clk: sdhci-ref-clk {
		compatible = "fixed-clock";
		clock-frequency = <50000000>;
		#clock-cells = <0>;
	};

	adma_ref_clk: adma_ref_clk {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <450000000>;
	};

	wwdtclk: wwdtclk {
		compatible = "fixed-clock";
		clock-frequency = <150000000>;
		#clock-cells = <0>;
	};
};

&cpu0 {
	 clock-frequency = <100000000>;
};

&soc {
	sram0: memory@30000 {
		compatible = "mmio-sram";
		reg = <0x30000 0x7ffd0000>;
	};

	tcm: memory@0 {
		compatible = "mmio-sram";
		reg = <0x0 0x10000>;
	};
};

&ocm {
	status = "okay";
};

&uart1 {
	status = "okay";
	current-speed = <115200>;
	clock-frequency = <100000000>;
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	clock-frequency = <100000000>;
};

&ufs0 {
	status = "okay";
	clocks = <&ufs_core_clk>;
	clock-names = "core_clk";

	ufs_disk0 {
		compatible = "zephyr,ufs-disk";
		disk-name = "UFS";
		status = "okay";
	};
};

&sdhci0 {
	status = "okay";
	power-delay-ms = <10>;
	clocks = <&sdhci_ref_clk>;
};

&sdhci1 {
	status = "okay";
	clocks = <&sdhci_ref_clk>;
};

&adma0 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma1 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma2 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma3 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma4 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma5 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma6 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma7 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&lpd_wwdt0 {
	status = "okay";
	clocks = <&wwdtclk>;
};
