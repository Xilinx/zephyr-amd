/dts-v1/;

/ {
	cpus: cpus {
		#address-cells = <1>;
		#size-cells = <0>;
		#cpus = <1>;

		cpu_0: cpu@0 {
			compatible = "rv32-riscv-cpu";
			interrupt-controller;
			#interrupt-cells = <1>;
			reg = <0>;
			i = <1>;
			m = <1>;
			a = <1>;
			f = <1>;
			c = <1>;
			d = <0>;
			h = <0>;
			mmu = <1>;
		};
	};

	qemu_sysmem {
		#address-cells = <2>;
		#size-cells = <2>;
		compatible = "qemu:system-memory";
		interrupt-parent = <&axi_intc>;

		ram@0 {
			compatible = "qemu:memory-region";
			qemu,ram = <1>;
			reg = <0 0 0 0x8000>;
		};

		ddr@80000000 {
			compatible = "qemu:memory-region";
			qemu,ram = <1>;
			reg = <0 0x80000000 0 0x80000000>;
		};

		axi_intc: interrupt-controller@41200000 {
			compatible = "xlnx.xps-intc";
			reg = <0 0x41200000 0 0x1000>;
			interrupt-controller;
			#interrupt-cells = <2>;
			interrupts-extended = <&cpu_0 11>;
			kind-of-intr = <0x1a>;
			interrupt-names = "Outputs";
		};

		xlnx_timer0: timer@41c00000 {
			compatible = "xlnx.xps-timer";
			reg = <0 0x41c00000 0 0x1000>;
			interrupts = <0 2>;
			clock-frequency = <100000000>;
		};

		uart0: serial@40600000  {
			compatible = "xlnx,xps-uartlite";
			reg = <0 0x40600000 0 0x1000>;
			chardev = "serial0";
			interrupts = <1 2>;
		};

		xlnx_timer2: timer@41c10000 {
			compatible = "xlnx.xps-timer";
			reg = <0 0x41c10000 0 0x1000>;
			interrupts = <6 2>;
			clock-frequency = <100000000>;
		};


		enet: ethernet@40c00000 {
			axistream-connected = <&dma>;
			axistream-control-connected = <&dma>;
			compatible = "xlnx,axi-ethernet-7.1", "xlnx,axi-ethernet-1.00.a";
			interrupt-names = "interrupt";
			interrupts = <7 2>;
			reg = <0 0x40c00000 0 0x40000>;
			phy-handle = <&phy>;

			mdio {
				#address-cells = <1>;
				#size-cells = <0>;

				phy: phy@7 {
					device_type = "ethernet-phy";
					reg = <7>;
				};
			};
		};

		dma: dma@41e00000 {
			axistream-connected = <&enet>;
			axistream-control-connected = <&enet>;
			compatible = "xlnx,eth-dma";
			interrupt-names = "mm2s_introut", "s2mm_introut";
			interrupts = <8 2 9 2>;
			reg = <0 0x41e00000 0 0x10000>;
		};

		axi_gpio2: gpio@40010000 {
			compatible = "xlnx,xps-gpio-1.00.a", "xlnx,eth-dma";
			reg = <0 0x40010000 0 0x10000>;
			gpio-controller;
			interrupts = <11 2>;
			#gpio-cells = <2>;
			xlnx,all-inputs = <0>;
			xlnx,tri-default = <0xffffffff>;
			xlnx,gpio2-width = <0x20>;
			xlnx,dout-default-2 = <0>;
			xlnx,all-outputs-2 = <0>;
			xlnx,all-inputs-2 = <0>;
			xlnx,tri-default-2 = <0xffffffff>;
			xlnx,is-dual = <0>;
			xlnx,dout-default = <0>;
			xlnx,gpio-width = <2>;
			xlnx,all-outputs = <0>;
		};
	};
};
