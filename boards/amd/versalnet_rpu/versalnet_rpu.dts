/dts-v1/;
#include <arm/xilinx/versalnet_r52.dtsi>

/ {
	chosen {
		zephyr,sram = &sram0;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,ocm = &ocm;
	};

	aliases {
		dma0 = &adma0;
		dma1 = &adma1;
		dma2 = &adma2;
		dma3 = &adma3;
		dma4 = &adma4;
		dma5 = &adma5;
		dma6 = &adma6;
		dma7 = &adma7;
		watchdog0 = &wwdt0;
	};

	sdhci_ref_clk: sdhci-ref-clk {
		compatible = "fixed-clock";
		clock-frequency = <200000000>;
		#clock-cells = <0>;
	};

	wwdtclk: wwdt-clk {
		compatible = "fixed-clock";
		clock-frequency = <150000000>;
		#clock-cells = <0>;
	};

	spi_ref_clk: spi-ref-clk {
		compatible = "fixed-clock";
		status = "okay";
		clock-frequency = <200000000>;
		#clock-cells = <0> ;
	};

	adma_ref_clk: adma-ref-clk {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <450000000>;
	};
};

&spi0 {
	status = "okay";
	clock-frequency = <200000000>;
	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <8000000>;
		jedec-id = [ 20 20 14 ]; /* m25p80 */
		size = <0x2000000>; /* 32Mb */
		has-dpd;
		t-enter-dpd = <10000>;
		t-exit-dpd = <35000>;
		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			storage_partition: partition@0 {
				label = "storage";
				reg = <0 0x2000000>;
			};
		};
	};
};

&cpu0 {
	clock-frequency = <100000000>;
};

&soc {
	sram0: memory@30000 {
		compatible = "mmio-sram";
		reg = <0x30000 DT_SIZE_M(2047)>;
	};

	tcm: memory@0 {
		compatible = "mmio-sram";
		reg = <0x0 DT_SIZE_K(64)>;
	};
};

&ocm {
	status = "okay";
};

&uart1 {
	status = "okay";
	current-speed = <115200>;
	clock-frequency = <100000000>;
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	clock-frequency = <100000000>;
};

&sdhci0 {
	status = "okay";
	power-delay-ms = <10>;
	clocks = <&sdhci_ref_clk>;
};

&sdhci1 {
	status = "okay";
	clocks = <&sdhci_ref_clk>;
};

&wwdt0 {
	status = "okay";
	clocks = <&wwdtclk>;
};

&wwdt1 {
	status = "okay";
	clocks = <&wwdtclk>;
};

&wwdt2 {
	status = "okay";
	clocks = <&wwdtclk>;
};

&wwdt3 {
	status = "okay";
	clocks = <&wwdtclk>;
};

&lpd_wwdt0 {
	status = "okay";
	clocks = <&wwdtclk>;
};

&pmc_wwdt {
	status = "okay";
	clocks = <&wwdtclk>;
};

&adma0 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma1 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma2 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma3 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma4 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma5 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma6 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};

&adma7 {
	status = "okay";
	clocks = <&adma_ref_clk>, <&adma_ref_clk>;
};
