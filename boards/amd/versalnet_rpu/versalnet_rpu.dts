/dts-v1/;
#include <arm/xilinx/versalnet_r52.dtsi>

/ {
	chosen {
		zephyr,sram = &sram0;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,ocm = &ocm;
	};

	wwdtclk: wwdt-clk {
		compatible = "fixed-clock";
		clock-frequency = <150000000>;
		#clock-cells = <0>;
	};

	sdhci_ref_clk: sdhci-ref-clk {
		compatible = "fixed-clock";
		clock-frequency = <200000000>;
		#clock-cells = <0>;
	};

	spi_ref_clk: spi-ref-clk {
		compatible = "fixed-clock";
		status = "okay";
		clock-frequency = <200000000>;
		#clock-cells = <0> ;
	};
};

&spi0 {
	status = "okay";
	cdns,num-ss-bits = <3>;
	is-decoded-cs = <0>;
	clocks = <&spi_ref_clk>;
	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <8000000>;
		jedec-id = [ 20 20 14 ]; /* m25p80 */
		size = <0x2000000>; /* 32Mb */
		has-dpd;
		t-enter-dpd = <10000>;
		t-exit-dpd = <35000>;
	};
};

&cpu0 {
	 clock-frequency = <100000000>;
};

&soc {
	sram0: memory@30000 {
		compatible = "mmio-sram";
		reg = <0x30000 0x7ffd0000>;
	};
};

&ocm {
	status = "okay";
};

&uart1 {
	status = "okay";
	current-speed = <115200>;
	clock-frequency = <100000000>;
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	clock-frequency = <100000000>;
};

&wwdt0 {
	status = "okay";
	clocks = <&wwdtclk>;
};

&wwdt1 {
	status = "okay";
	clocks = <&wwdtclk>;
};

&wwdt2 {
	status = "okay";
	clocks = <&wwdtclk>;
};

&wwdt3 {
	status = "okay";
	clocks = <&wwdtclk>;
};

&lpd_wwdt0 {
	status = "okay";
	clocks = <&wwdtclk>;
};

&pmc_wwdt {
	status = "okay";
	clocks = <&wwdtclk>;
};

&sdhci0 {
	status = "okay";
	power-delay-ms = <10>;
	clocks = <&sdhci_ref_clk>;
};

&sdhci1 {
	status = "okay";
	clocks = <&sdhci_ref_clk>;
};
